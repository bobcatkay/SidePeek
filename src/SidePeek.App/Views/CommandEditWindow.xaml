<Window x:Class="SidePeek.App.Views.CommandEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:svc="clr-namespace:SidePeek.App.Services"
        xmlns:sw="clr-namespace:System.Windows;assembly=PresentationFramework"
        Title="命令"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Topmost="True"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Grayscale"
        TextOptions.TextHintingMode="Animated"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="GlyphPick" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="B" Width="40" Height="40" CornerRadius="8"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="Transparent" BorderThickness="2">
                            <TextBlock Text="{Binding}" FontSize="18" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="B" Property="BorderBrush"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorPick" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="B" Width="28" Height="28" CornerRadius="14"
                                BorderBrush="Transparent" BorderThickness="3">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding}" />
                            </Border.Background>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="B" Property="BorderBrush"
                                        Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="22">
        <TextBlock x:Name="HeaderText" Text="添加命令" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />

        <TextBlock Text="标题 *" Margin="0,0,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <ui:TextBox x:Name="TitleBox" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="例如：清理临时文件" />

        <TextBlock Text="描述" Margin="0,12,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <ui:TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="可选" />

        <TextBlock Text="图标" Margin="0,12,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <ListBox x:Name="GlyphList" ItemsSource="{x:Static svc:IconCatalog.Glyphs}"
                 SelectedItem="{Binding Glyph, Mode=TwoWay}"
                 ItemContainerStyle="{StaticResource GlyphPick}"
                 BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>

        <TextBlock Text="强调色" Margin="0,8,0,4" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <ListBox x:Name="ColorList" ItemsSource="{x:Static svc:IconCatalog.Accents}"
                 SelectedItem="{Binding AccentHex, Mode=TwoWay}"
                 ItemContainerStyle="{StaticResource ColorPick}"
                 BorderThickness="0" Background="Transparent">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>

        <TextBlock Text="命令 *（每行一条，按顺序执行）" Margin="0,12,0,4"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <ui:TextBox Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}"
                    AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" MaxHeight="160"
                    VerticalScrollBarVisibility="Auto"
                    PlaceholderText="echo hello&#x0a;ping 127.0.0.1 -n 1" />

        <Grid Margin="0,12,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="参数" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:Button Content="+"
                           MinWidth="34"
                           Padding="0"
                           Margin="10,0,0,0"
                           Click="OnAddParameter"
                           ToolTip="增加参数" />
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Text="命令中按顺序使用 %1、%2、%3 引用参数。"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </Grid>

        <ScrollViewer MaxHeight="250"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Parameters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,8,0,0"
                                Padding="10"
                                CornerRadius="8"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="155" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="参数名称" />
                                    <ui:Button Grid.Column="2"
                                               Appearance="Transparent"
                                               Padding="4"
                                               Margin="10,0,0,0"
                                               Icon="{ui:SymbolIcon Delete24}"
                                               Click="OnRemoveParameter"
                                               ToolTip="删除参数" />
                                    <StackPanel Grid.Row="1"
                                                Grid.ColumnSpan="3"
                                                Orientation="Horizontal"
                                                Margin="0,8,0,0">
                                        <RadioButton Content="执行时输入"
                                                     Margin="0,0,14,0"
                                                     IsChecked="{Binding IsPrompt, Mode=TwoWay}" />
                                        <RadioButton Content="候选值"
                                                     IsChecked="{Binding UsesChoices, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>

                                <Border Margin="0,8,0,0"
                                        Visibility="{Binding IsPrompt, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="默认值"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <ui:TextBox Margin="0,4,0,0"
                                                    Text="{Binding PromptDefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                                    PlaceholderText="可选，执行时自动填入" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,8,0,0"
                                        Visibility="{Binding UsesChoices, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="候选值"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Text="（☑️设置默认值）"
                                                       FontSize="11"
                                                       Margin="4,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <ui:Button Content="+"
                                                       MinWidth="30"
                                                       Padding="0"
                                                       Margin="10,0,0,0"
                                                       Click="OnAddChoice"
                                                       ToolTip="增加候选值" />
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding Choices}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,6,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox VerticalAlignment="Center"
                                                                  Margin="0,0,8,0"
                                                                  ToolTip="默认值"
                                                                  IsChecked="{Binding IsDefault, Mode=TwoWay}"
                                                                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  Checked="OnDefaultChoiceChecked" />
                                                        <ui:TextBox Grid.Column="1"
                                                                    PlaceholderText="标签"
                                                                    Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ui:TextBox Grid.Column="2"
                                                                    Margin="8,0,0,0"
                                                                    PlaceholderText="值"
                                                                    Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                        <ui:Button Grid.Column="3"
                                                                   Margin="8,0,0,0"
                                                                   Appearance="Transparent"
                                                                   Padding="4"
                                                                   Icon="{ui:SymbolIcon Delete24}"
                                                                   Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   Click="OnRemoveChoice"
                                                                   ToolTip="删除候选值" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="ErrorText" Foreground="#E53935" Margin="0,10,0,0" Visibility="Collapsed" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <ui:Button Content="取消" MinWidth="80" Margin="0,0,10,0" Click="OnCancel" />
            <ui:Button Content="保存" Appearance="Primary" MinWidth="80" Click="OnSave" />
        </StackPanel>
    </StackPanel>
</Window>
