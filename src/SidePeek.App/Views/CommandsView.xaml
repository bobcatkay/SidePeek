<UserControl x:Class="SidePeek.App.Views.CommandsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:SidePeek.App.Converters"
             xmlns:vm="clr-namespace:SidePeek.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:CommandsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />

        <Style x:Key="CardDescriptionText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="LineHeight" Value="14" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
        </Style>

        <Style x:Key="CardRun" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardMenu" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="11" Background="Transparent">
                            <TextBlock Text="&#x22EE;" FontSize="16" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI Symbol, Segoe UI"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RuntimeChoiceItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" CornerRadius="7" Padding="8,6" Background="Transparent">
                            <RadioButton Content="{Binding Label}"
                                         IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}"
                                         IsHitTestVisible="False"
                                         Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="CommandRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">
            <TextBlock Text="快捷命令" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <ui:Button DockPanel.Dock="Right" HorizontalAlignment="Right" Appearance="Primary"
                       Icon="{ui:SymbolIcon Add24}" Content="添加" Click="OnAdd" />
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
            <ItemsControl ItemsSource="{Binding Commands}" VerticalAlignment="Top">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="78" Margin="4,0,4,8" AllowDrop="True"
                              PreviewMouseLeftButtonDown="OnItemMouseDown"
                              PreviewMouseMove="OnItemMouseMove"
                              DragOver="OnItemDragOver"
                              Drop="OnItemDrop">
                            <Button Style="{StaticResource CardRun}" Click="OnRun" ToolTip="点击执行">
                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="20" VerticalAlignment="Center"
                                            Background="{Binding AccentHex, Converter={StaticResource StringToBrush}}">
                                        <TextBlock Text="{Binding Glyph}" FontSize="18.125" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource CardDescriptionText}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource CardMenu}" HorizontalAlignment="Right"
                                    VerticalAlignment="Top" Margin="0,6,6,0"
                                    Click="OnItemMenu" ToolTip="更多" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid x:Name="ParameterPromptLayer"
              Grid.RowSpan="2"
              Panel.ZIndex="40"
              Visibility="Collapsed"
              Background="#33000000">
            <Border x:Name="ParameterPromptPanel"
                    Width="320"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Padding="14"
                    CornerRadius="10"
                    Background="#FFFFFFFF"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="ParameterPromptTitle"
                               Text="参数设置"
                               FontSize="15"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Stretch"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                    <ScrollViewer Margin="0,10,0,0"
                                  MaxHeight="360"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ParameterPromptList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <ui:TextBox Margin="0,4,0,0"
                                                    Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Visibility="{Binding InputVisibility}" />
                                        <ListBox Margin="0,4,0,0"
                                                 ItemsSource="{Binding Choices}"
                                                 SelectedItem="{Binding SelectedChoice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ItemContainerStyle="{StaticResource RuntimeChoiceItem}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Visibility="{Binding ChoiceVisibility}">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                        </ListBox>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="ParameterPromptError"
                               Foreground="#E53935"
                               FontSize="12"
                               Visibility="Collapsed" />

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <ui:Button Content="取消"
                                   MinWidth="72"
                                   Margin="0,0,10,0"
                                   Click="OnCancelParameterPrompt" />
                        <ui:Button Content="执行"
                                   Appearance="Primary"
                                   MinWidth="72"
                                   Click="OnConfirmParameterPrompt" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
