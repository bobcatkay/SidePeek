<UserControl x:Class="SidePeek.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:SidePeek.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <UserControl.Resources>
        <Style x:Key="SettingsGroup" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SettingLabel" TargetType="TextBlock" BasedOn="{StaticResource CrispSmallTextBlock}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="设置" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock DockPanel.Dock="Right" Text="{Binding VersionText}" FontSize="12"
                       Style="{StaticResource CrispSmallTextBlock}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <StackPanel>
                <Border Style="{StaticResource SettingsGroup}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="2" Text="停靠" FontSize="15" FontWeight="SemiBold"
                                   Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="1" Style="{StaticResource SettingLabel}" Text="显示器" />
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding DockDisplays}"
                                  SelectedItem="{Binding SelectedDockDisplay, Mode=TwoWay}"
                                  DisplayMemberPath="Label" />

                        <TextBlock Grid.Row="2" Style="{StaticResource SettingLabel}" Text="停靠边" Margin="0,12,0,0" />
                        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,12,0,0"
                                  ItemsSource="{Binding DockEdges}"
                                  SelectedItem="{Binding SelectedDockEdge, Mode=TwoWay}"
                                  DisplayMemberPath="Label" />

                        <TextBlock Grid.Row="3" Style="{StaticResource SettingLabel}" Text="收起延时" Margin="0,12,0,0" />
                        <Grid Grid.Row="3" Grid.Column="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="150" Maximum="2000" TickFrequency="50"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding CollapseDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="1" Text="{Binding CollapseDelayMs, StringFormat={}{0:0} ms}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsGroup}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="2" Text="便签" FontSize="15" FontWeight="SemiBold"
                                   Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="1" Style="{StaticResource SettingLabel}" Text="历史保留" />
                        <Grid Grid.Row="1" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="52" />
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="1" Maximum="60" TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding NoteHistoryMonths, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="1" Text="{Binding NoteHistoryMonths, StringFormat={}{0:0} 月}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsGroup}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="2" Text="外观" FontSize="15" FontWeight="SemiBold"
                                   Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="1" Style="{StaticResource SettingLabel}" Text="主题" />
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding Themes}"
                                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                  DisplayMemberPath="Label" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsGroup}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="启动" FontSize="15" FontWeight="SemiBold"
                                   Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <CheckBox Grid.Row="1" Content="开机自启"
                                  IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SettingsGroup}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="2" Text="全局热键" FontSize="15" FontWeight="SemiBold"
                                   Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <TextBlock Grid.Row="1" Style="{StaticResource SettingLabel}" Text="组合键" />
                        <WrapPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                            <CheckBox Content="Ctrl" Margin="0,0,10,0"
                                      IsChecked="{Binding HotkeyControl, Mode=TwoWay}" />
                            <CheckBox Content="Alt" Margin="0,0,10,0"
                                      IsChecked="{Binding HotkeyAlt, Mode=TwoWay}" />
                            <CheckBox Content="Shift"
                                      IsChecked="{Binding HotkeyShift, Mode=TwoWay}" />
                        </WrapPanel>

                        <TextBlock Grid.Row="2" Style="{StaticResource SettingLabel}" Text="按键" Margin="0,12,0,0" />
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding HotkeyKeys}"
                                      SelectedItem="{Binding HotkeyKey, Mode=TwoWay}" />
                            <Border Grid.Column="1" Margin="10,0,0,0" CornerRadius="8" Padding="10,0"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <TextBlock Text="{Binding HotkeyPreview}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
