<UserControl x:Class="SidePeek.App.Views.WidgetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:SidePeek.App.Converters"
             xmlns:vm="clr-namespace:SidePeek.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:WidgetsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Loaded="OnLoaded" Unloaded="OnUnloaded">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />

        <Style x:Key="CardRun" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardDelete" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="11" Background="Transparent">
                            <TextBlock Text="&#xE711;" FontSize="11" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E53935" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="小工具" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

        <!-- 时钟 -->
        <Border Grid.Row="1" CornerRadius="12" Margin="0,0,0,10" Padding="18,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#3A6BD6" Offset="0" />
                    <GradientStop Color="#5B8DEF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="{Binding Time}" FontSize="42" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="{Binding Date}" FontSize="13" Margin="2,2,0,0" Foreground="#E2EAFB" />
            </StackPanel>
        </Border>

        <!-- 内存 -->
        <Border Grid.Row="2" CornerRadius="12" Margin="0,0,0,16" Padding="18,14"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="&#xE950;" Margin="0,0,8,0" FontSize="18"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    <TextBlock Text="{Binding MemoryText}" DockPanel.Dock="Right" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="内存占用" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </DockPanel>
                <ProgressBar Margin="0,10,0,0" Height="8" Minimum="0" Maximum="100"
                             Value="{Binding MemoryUsedPercent}" />
            </StackPanel>
        </Border>

        <!-- 启动器标题 + 添加 -->
        <DockPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="应用启动器" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <ui:Button DockPanel.Dock="Right" HorizontalAlignment="Right" Appearance="Primary"
                       Icon="{ui:SymbolIcon Add24}" Content="添加" Click="OnAddTool" />
        </DockPanel>

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <ItemsControl ItemsSource="{Binding Tools}" VerticalAlignment="Top">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="78" Margin="0,0,8,8">
                            <Button Style="{StaticResource CardRun}" Click="OnLaunchTool" ToolTip="点击启动">
                                <Grid Margin="12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="20" VerticalAlignment="Center"
                                            Background="{Binding AccentHex, Converter={StaticResource StringToBrush}}">
                                        <TextBlock Text="{Binding Glyph}" FontSize="18" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0,18,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Description}" FontSize="11" Margin="0,1,0,0"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Style="{StaticResource CardDelete}" HorizontalAlignment="Right"
                                    VerticalAlignment="Top" Margin="0,6,6,0"
                                    Click="OnDeleteTool" ToolTip="删除" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
