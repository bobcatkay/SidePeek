<Window x:Class="SidePeek.App.Views.CommandRunnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:sw="clr-namespace:System.Windows;assembly=PresentationFramework"
        Title="执行命令"
        Width="640" Height="460"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        FontFamily="{x:Static sw:SystemFonts.MessageFontFamily}"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <ui:ProgressRing x:Name="Spinner" DockPanel.Dock="Left" Width="20" Height="20"
                             IsIndeterminate="True" Margin="0,0,10,0" />
            <TextBlock x:Name="HeaderText" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </DockPanel>

        <Border Grid.Row="1" CornerRadius="8" Background="#11141A">
            <ScrollViewer x:Name="Scroller" Padding="12" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="Output" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                         Foreground="#D5DBE5" FontFamily="Cascadia Mono, Consolas, monospace"
                         FontSize="12.5" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <ui:Button x:Name="CloseButton" Content="关闭" Appearance="Primary" MinWidth="84" Click="OnClose" />
        </StackPanel>
    </Grid>
</Window>
