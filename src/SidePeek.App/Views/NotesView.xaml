<UserControl x:Class="SidePeek.App.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:SidePeek.App.Converters"
             xmlns:vm="clr-namespace:SidePeek.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:NotesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Loaded="OnLoaded" Unloaded="OnUnloaded">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />

        <Style x:Key="ClockTimeText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
            <Setter Property="FontSize" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="SnapsToDevicePixels" Value="False" />
            <Setter Property="UseLayoutRounding" Value="False" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
            <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale" />
            <Setter Property="TextOptions.TextHintingMode" Value="Animated" />
        </Style>

        <Style x:Key="HeaderToggleIconButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" CornerRadius="8" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">
            <TextBlock Text="便签" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <ToggleButton Style="{StaticResource HeaderToggleIconButton}"
                              IsChecked="{Binding ShowCompleted, Mode=TwoWay}"
                              ToolTip="已完成">
                    <ui:SymbolIcon Symbol="History24" />
                </ToggleButton>
                <ui:Button Appearance="Primary"
                           Icon="{ui:SymbolIcon Add24}" Content="新建"
                           Command="{Binding AddNoteCommand}" />
            </StackPanel>
        </DockPanel>

        <StackPanel Grid.Row="1" Margin="0,0,4,12">
            <Border CornerRadius="12" Margin="0,0,0,10" Padding="18,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3A6BD6" Offset="0" />
                        <GradientStop Color="#5B8DEF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="{Binding Time}" Style="{StaticResource ClockTimeText}" />
                    <TextBlock Text="{Binding Date}" FontSize="13" Margin="2,2,0,0" Foreground="#E2EAFB" />
                </StackPanel>
            </Border>

            <Border CornerRadius="12" Padding="18,14"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="&#xE950;" Margin="0,0,8,0" FontSize="18"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="{Binding MemoryText}" DockPanel.Dock="Right" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="内存占用" Style="{StaticResource CrispSmallTextBlock}"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </DockPanel>
                    <ProgressBar Margin="0,10,0,0" Height="8" Minimum="0" Maximum="100"
                                 Value="{Binding MemoryUsedPercent}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0"
                      Visibility="{Binding ActiveVisibility}">
            <ItemsControl ItemsSource="{Binding Notes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" CornerRadius="10" AllowDrop="True"
                                PreviewMouseLeftButtonDown="OnItemMouseDown"
                                PreviewMouseMove="OnItemMouseMove"
                                DragOver="OnItemDragOver"
                                Drop="OnItemDrop"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="{Binding ColorHex, Converter={StaticResource StringToBrush}}"
                                        CornerRadius="10,0,0,10" />
                                <Grid Grid.Column="1" Margin="12,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <DockPanel>
                                        <ui:SymbolIcon DockPanel.Dock="Left" Symbol="Pin24" Margin="0,0,6,0"
                                                       Foreground="{Binding ColorHex, Converter={StaticResource StringToBrush}}"
                                                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}" />
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <ui:Button Appearance="Transparent" Padding="6"
                                                       Icon="{ui:SymbolIcon Pin24}"
                                                       ToolTip="置顶"
                                                       Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />
                                            <ui:Button Appearance="Transparent" Padding="6"
                                                       Icon="{ui:SymbolIcon CheckmarkCircle24}"
                                                       ToolTip="完成"
                                                       Command="{Binding DataContext.CompleteNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />
                                            <ui:Button Appearance="Transparent" Padding="6"
                                                       Icon="{ui:SymbolIcon Delete24}"
                                                       ToolTip="删除"
                                                       Click="OnDeleteNote" />
                                        </StackPanel>
                                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="15" FontWeight="SemiBold" BorderThickness="0"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </DockPanel>
                                    <TextBox Grid.Row="1" Margin="0,6,0,0"
                                             Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0"
                                             Background="Transparent" MaxHeight="120"
                                             VerticalScrollBarVisibility="Auto"
                                             Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" Visibility="{Binding CompletedVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,4,10">
                <TextBlock Text="已完成" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <ComboBox DockPanel.Dock="Right" Width="112"
                          ItemsSource="{Binding HistoryRanges}"
                          SelectedItem="{Binding SelectedHistoryRange, Mode=TwoWay}"
                          DisplayMemberPath="Label" />
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <ItemsControl ItemsSource="{Binding VisibleCompletedNotes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10" CornerRadius="10"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{Binding ColorHex, Converter={StaticResource StringToBrush}}"
                                            CornerRadius="10,0,0,10" />
                                    <Grid Grid.Column="1" Margin="12,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <DockPanel>
                                            <ui:Button DockPanel.Dock="Right" Appearance="Transparent" Padding="6"
                                                       Icon="{ui:SymbolIcon ArrowUndo24}"
                                                       ToolTip="恢复"
                                                       Command="{Binding DataContext.RestoreNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />
                                            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                        <TextBlock Grid.Row="1" Margin="0,4,0,0"
                                                   Text="{Binding CompletedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Grid.Row="2" Margin="0,6,0,0"
                                                   Text="{Binding Content}" TextWrapping="Wrap" MaxHeight="96"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid x:Name="DeleteConfirmOverlay"
              Grid.RowSpan="3"
              Panel.ZIndex="20"
              Visibility="Collapsed"
              Background="#33000000">
            <Border Width="306"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="12"
                    Padding="18"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <ui:SymbolIcon Symbol="Delete24"
                                       FontSize="20"
                                       Margin="0,0,8,0"
                                       Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="DeleteConfirmTitle"
                                   Text="删除便签"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="DeleteConfirmMessage"
                               Text="确定要删除这条便签吗？删除后无法恢复。"
                               TextWrapping="Wrap"
                               Style="{StaticResource CrispSmallTextBlock}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,18,0,0">
                        <ui:Button Content="取消"
                                   MinWidth="72"
                                   Margin="0,0,10,0"
                                   Click="OnCancelDelete" />
                        <ui:Button Content="删除"
                                   Appearance="Primary"
                                   MinWidth="72"
                                   Click="OnConfirmDelete" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
